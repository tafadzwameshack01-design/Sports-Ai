# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Optional: override the bundled trial key with a paid SportRadar key ───────
# Trial key is rate-limited to ~1 req/s and NBA only.
# Paid keys unlock higher rate limits, multiple sports, and historical data.
SPORTRADAR_API_KEY=your_sportradar_api_key_here
